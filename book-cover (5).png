// ─── FAQ ──────────────────────────────────────────────────────────────────────
const FAQS = [
  { q: 'How do I book a session with Star?', a: 'Click "Book Now" from any page and select your service. Choose your date and time, complete your information, and you\'ll be directed to secure Stripe checkout. You\'ll receive a confirmation email with everything you need to prepare.' },
  { q: 'Are sessions available in person or remotely?', a: 'Most readings can be conducted via phone or video call as well as in person at 351 S. Wells Ave, Suite 200, Reno, NV. Ritual services are typically conducted on-site.' },
  { q: 'What is your cancellation and refund policy?', a: 'Cancellations made 48+ hours before your session receive a full refund. Cancellations within 48 hours are non-refundable but may be rescheduled once. No-shows are non-refundable.' },
  { q: 'How should I prepare for my session?', a: 'Come with an open heart and a quiet mind. Write down your intentions or questions beforehand. Avoid alcohol for 24 hours before a session. Arrive 10 minutes early for in-person visits.' },
  { q: 'What exactly happens during a hex removal?', a: 'Star identifies the nature and source of the energetic interference through intuitive assessment. The removal involves a three-hour ceremonial process using sacred prayer, ritual materials, and Star\'s direct spiritual intervention. A protective sealing is completed at the end.' },
  { q: 'How is hypnosis different from a reading?', a: 'Readings are intuitive — Star receives information from the spiritual realm to guide you. Hypnosis is clinical — it works directly on your subconscious to reprogram patterns, release trauma, and install new beliefs.' },
  { q: 'Where can I get Star\'s book?', a: 'Life After Death is available on Amazon. You can also purchase a personally signed copy directly through this website. Signed copies include a handwritten note and ship within 5–7 business days.' },
  { q: 'Can Star contact a specific deceased loved one?', a: 'Star can open the channel and invite contact, but communication comes through on their terms. She will relay everything that comes through clearly and honestly. Most clients find that loved ones do come through — often with details only they could know.' },
]

function FAQ() {
  const [openIdx, setOpenIdx] = useState<number | null>(null)

  return (
    <section id="faq" style={{ background: '#080808', padding: '100px 20px' }}>
      <div style={{ maxWidth: 1200, margin: '0 auto' }}>
        <span className="section-label reveal">Questions</span>
        <h2 className="section-title gold-text reveal">Common Questions</h2>
        <div className="reveal" style={{ maxWidth: 760, margin: '60px auto 0' }}>
          {FAQS.map(({ q, a }, i) => (
            <div key={i} style={{ borderBottom: '1px solid rgba(255,255,255,0.06)', overflow: 'hidden' }}>
              <button onClick={() => setOpenIdx(openIdx === i ? null : i)}
                style={{ width: '100%', display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '24px 0', background: 'none', border: 'none', textAlign: 'left', cursor: 'pointer', gap: 20 }}>
                <span style={{ fontFamily: "'Cinzel', serif", fontSize: '0.8rem', letterSpacing: '0.08em', color: '#F5EDD6' }}>{q}</span>
                <span style={{ color: '#C9A84C', fontSize: '1.2rem', flexShrink: 0, transition: 'transform 0.3s', transform: openIdx === i ? 'rotate(45deg)' : 'none' }}>+</span>
              </button>
              <div style={{ maxHeight: openIdx === i ? 300 : 0, overflow: 'hidden', transition: 'max-height 0.4s ease' }}>
                <p style={{ fontFamily: "'Cormorant Garamond', serif", fontSize: '1.05rem', lineHeight: 1.75, color: '#D4C4A0', paddingBottom: 24 }}>{a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

// ─── Inner Circle ─────────────────────────────────────────────────────────────
function InnerCircle() {
  const [submitted, setSubmitted] = useState(false)
  const [name, setName] = useState('')
  const [email, setEmail] = useState('')

  const inputStyle: React.CSSProperties = {
    width: '100%', background: 'rgba(255,255,255,0.03)',
    border: '1px solid rgba(201,168,76,0.2)', color: '#F5EDD6',
    fontFamily: "'Cormorant Garamond', serif", fontSize: '1rem',
    padding: '16px 20px', outline: 'none', letterSpacing: '0.04em',
  }

  return (
    <section id="inner-circle" style={{ background: 'linear-gradient(135deg,#0d0308 0%,#0a0515 50%,#080808 100%)', padding: '100px 20px', textAlign: 'center', position: 'relative', overflow: 'hidden' }}>
      <div style={{ position: 'absolute', inset: 0, background: 'radial-gradient(ellipse 70% 50% at 50% 50%, rgba(74,14,107,0.2) 0%, transparent 70%)', pointerEvents: 'none' }} />
      <div className="reveal" style={{ maxWidth: 480, margin: '0 auto', position: 'relative', zIndex: 2 }}>
        <span className="section-label">The Inner Circle</span>
        <h2 className="section-title gold-text">Enter the Inner Circle</h2>
        {submitted ? (
          <p style={{ fontFamily: "'Cinzel', serif", fontSize: '0.75rem', letterSpacing: '0.2em', color: '#C9A84C', padding: '32px 0' }}>✦ Welcome, {name}. You are now within the circle. ✦</p>
        ) : (
          <>
            <p style={{ fontFamily: "'Cormorant Garamond', serif", fontStyle: 'italic', fontSize: '1.15rem', color: '#D4C4A0', marginBottom: 32, lineHeight: 1.7 }}>
              Receive Star's new moon messages, exclusive spiritual guidance, first access to new offerings, and transmissions that never go public.
            </p>
            <form onSubmit={e => { e.preventDefault(); setSubmitted(true) }} style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
              <input type="text" placeholder="Your name" required value={name} onChange={e => setName(e.target.value)} style={inputStyle} />
              <input type="email" placeholder="Your email address" required value={email} onChange={e => setEmail(e.target.value)} style={inputStyle} />
              <button type="submit" style={{ fontFamily: "'Cinzel', serif", fontSize: '0.65rem', letterSpacing: '0.3em', textTransform: 'uppercase', color: '#080808', background: 'linear-gradient(135deg,#8B6914,#C9A84C,#E8C96A)', border: 'none', padding: 18, cursor: 'pointer', marginTop: 4 }}>
                Enter the Inner Circle
              </button>
            </form>
            <p style={{ fontFamily: "'Cormorant Garamond', serif", fontSize: '0.8rem', color: '#D4C4A0', opacity: 0.4, marginTop: 16, fontStyle: 'italic' }}>Sacred space. No spam, ever.</p>
          </>
        )}
      </div>
    </section>
  )
}

