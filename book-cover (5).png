              <span style={{ fontFamily: "'Cormorant Garamond', serif", fontSize: '0.9rem', color: '#D4C4A0', fontStyle: 'italic' }}>{label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

