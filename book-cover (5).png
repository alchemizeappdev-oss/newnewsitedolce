        {/* Stats */}
        <div className="reveal" style={{ display: 'grid', gridTemplateColumns: 'repeat(3,1fr)', gap: 20, maxWidth: 500, margin: '0 auto', paddingTop: 48, borderTop: '1px solid rgba(201,168,76,0.15)' }}>
          {[['500+', 'Clients guided'], ['5★', 'Google rating'], ['10+', 'Years of practice']].map(([num, label]) => (
